# Copy to .env and fill in. LLM_BACKEND switches which client src/generation/generator.py uses --
# nothing else in the codebase needs to change.

LLM_BACKEND=groq          # "groq" (default, needs GROQ_API_KEY) or "ollama" (local, fully offline)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# only read when LLM_BACKEND=ollama
OLLAMA_MODEL=qwen2.5
OLLAMA_HOST=http://localhost:11434
